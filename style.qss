QMainWindow, QWidget {
    background: #202224;
    color: #f1f3f5;
    font-size: 13px;
}

QGroupBox {
    border: 1px solid #3b3f43;
    border-radius: 6px;
    margin-top: 14px;
    padding: 10px;
    background: #292c2f;
    font-weight: 600;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 4px;
}

QLabel {
    color: #f1f3f5;
}

QLabel#analogPrimaryValue {
    background: #101214;
    border: 1px solid #2da9e9;
    border-radius: 4px;
    color: #ffffff;
    font-size: 9px;
    font-weight: normal;
    padding: 3px 5px;
}

QLabel#analogPrimaryIntValue {
    background: #151719;
    border: 1px solid #3b3f43;
    border-radius: 4px;
    color: #dbe3ea;
    font-size: 9px;
    padding: 3px 5px;
}

QLabel#analogOutputValue {
    font-size: 8px;
}

QLabel#analogStatusOk {
    color: #b8c0c7;
    padding: 2px 4px;
}

QLabel#analogStatusWarning {
    color: #ffb454;
    font-weight: 700;
    padding: 2px 4px;
}

QLineEdit {
    background: #16181a;
    border: 1px solid #4b5158;
    border-radius: 4px;
    padding: 6px 8px;
    selection-background-color: #0077aa;
}

QLineEdit#analogInputNarrow {
    max-width: 42px;
    min-width: 34px;
    padding: 3px 5px;
}

QLineEdit#analogInputWide {
    max-width: 70px;
    min-width: 60px;
    font-size: 10px;
    padding: 3px 5px;
}

QComboBox#analogInputMode {
    max-width: 70px;
    min-width: 60px;
    padding: 3px 5px;
}

QLineEdit:focus {
    border: 1px solid #2da9e9;
}

QPushButton {
    background: #4d5358;
    border: 1px solid #626970;
    border-radius: 4px;
    padding: 5px 10px;
    font-weight: 600;
}

QPushButton#compactButton {
    padding: 2px 6px;
    min-height: 20px;
    max-height: 20px;
    font-size: 9px;
    font-weight: 500;
}

QPushButton#analogPresetButton {
    padding: 2px 6px;
    min-height: 17px;
    max-height: 17px;
    font-size: 8px;
}

QPushButton:hover {
    background: #5c646b;
}

QPushButton:pressed {
    background: #3d444a;
}

QTableWidget {
    background: #151719;
    alternate-background-color: #1b1e20;
    gridline-color: #2a2e32;
    border: 1px solid #343a40;
    selection-background-color: #005f88;
    selection-color: #ffffff;
}

QHeaderView::section {
    background: #2f3438;
    color: #f1f3f5;
    border: 0;
    border-right: 1px solid #4c535a;
    border-bottom: 1px solid #4c535a;
    padding: 3px 4px;
    font-size: 9px;
    font-weight: 600;
}

QLineEdit#ptnoInput {
    min-height: 21px;
    max-width: 158px;
    min-width: 140px;
    font-size: 11px;
    padding: 3px 5px;
}

QLineEdit#ptnoResult {
    min-height: 20px;
    max-width: 158px;
    min-width: 140px;
    font-size: 11px;
    padding: 3px 5px;
}

QLineEdit#searchInput {
    min-height: 22px;
    max-width: 160px;
    min-width: 130px;
    font-size: 10px;
    padding: 3px 5px;
}

QScrollBar:vertical, QScrollBar:horizontal {
    background: #202224;
    border: 0;
    width: 12px;
    height: 12px;
}

QScrollBar::handle:vertical, QScrollBar::handle:horizontal {
    background: #626970;
    border-radius: 4px;
    min-height: 24px;
    min-width: 24px;
}

QScrollBar::add-line, QScrollBar::sub-line {
    width: 0;
    height: 0;
}
